POSTGRES_PASSWORD=your_postgres_password
RAG_DATABASE_URL=postgresql://mcp_app:your_postgres_password@db:5433/notion_mcp
REDIS_PASSWORD=your_redis_password
GOVERNANCE_DB_ID=your_governance_database_id
AUDIT_DB_ID=your_audit_database_id
WORKFLOW_DB_ID=your_workflow_database_id
APPROVAL_DB_ID=your_approval_database_id
# Add any other required secrets or config here
#   - DO NOT use human-memorable secrets like "tenant-a" or "acme-prod"
#   - Generate strong keys: openssl rand -base64 32
#   - Inject from secret storage in production rather than persisting plaintext in .env
#
# Format: comma-separated list of "hmac_sha256_hex:workspace_uuid" pairs
# RAG_API_KEYS=a1b2c3d4e5f6...:11111111-1111-1111-1111-111111111111,f9e8d7c6b5a4...:22222222-2222-2222-2222-222222222222
RAG_API_KEYS=

# Notion OAuth credentials (optional — only needed for OAuth flow)
# NOTION_OAUTH_CLIENT_ID=your_oauth_client_id
# NOTION_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# NOTION_OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

# ============================================================================
# Timeout Configuration (3-layer defense)
# ============================================================================

# Application-level request timeout (seconds)
# Hard cap for the full request lifecycle - middleware enforces this on all endpoints
# Recommended: 15s
# REQUEST_TIMEOUT_SECONDS=15

# Dependency-level embedding timeout (seconds)
# Timeout for external embedding provider HTTP calls
# Recommended: 8s
# EMBED_TIMEOUT_SECONDS=8

# Database-level timeouts (milliseconds)
# Postgres statement_timeout for vector search queries
# Recommended: 3000ms (3 seconds)
# DB_SEARCH_TIMEOUT_MS=3000

# Postgres statement_timeout for ingest write queries
# Recommended: 10000ms (10 seconds)
# DB_INGEST_TIMEOUT_MS=10000

# ============================================================================
# Request & Concurrency Limits
# ============================================================================

# Maximum request body size (bytes)
# Prevents memory spikes from large payloads
# Recommended: 1000000 (1 MB)
# MAX_REQUEST_BODY_SIZE=1000000

# Maximum chunks per ingest request
# Early validation to prevent DB contention and query timeout
# Recommended: 200
# MAX_CHUNKS_PER_REQUEST=200

# Maximum concurrent ingest operations
# Semaphore limit to prevent DB connection pool exhaustion
# Recommended: 4
# MAX_CONCURRENT_INGESTS=4

# ============================================================================
# Rate Limiting
# ============================================================================

# Redis URL for distributed rate limiting (optional)
# If not set, uses in-memory rate limiting (single-instance only)
# For multi-instance deployments, use Redis for shared state across instances
# Format: redis://[[username]:[password]]@host:port/database
# Examples:
#   REDIS_URL=redis://localhost:6379/0
#   REDIS_URL=redis://redis:6379/0                   # Docker Compose service name
#   REDIS_URL=redis://:password@redis-server:6379/0
#   REDIS_URL=rediss://user:pass@redis.example.com:6380/0  # TLS
# REDIS_URL=

# Actor-signing secret for trusted stateless resource authorization
# Generate with: openssl rand -base64 32
# This secret signs X-Actor-Id / X-Actor-Type / X-Actor-Timestamp / X-Actor-Signature headers.
# Required in STRICT_PRODUCTION_MODE when RAG/resource.list is enabled.
# ACTOR_SIGNING_SECRET=CHANGE_ME_IN_PRODUCTION

# Maximum allowed clock skew / signature age in seconds for signed actor headers.
# Requests outside this window are rejected to reduce replay risk.
# ACTOR_SIGNATURE_MAX_AGE_SECONDS=300

# ============================================================================
# Development flags
# ============================================================================
# MCP_HTTP_MODE=1        # Force HTTP server mode (auto-detected in Docker)
# SKIP_NOTION_API=1      # Suppress live Notion writes during local/integration tests
# DEBUG=1                # Extra local debugging only; tracebacks are no longer exposed to clients by default
# ALLOW_DEBUG_TRACEBACKS=1  # Local-only escape hatch; do not enable in production
# STRICT_PRODUCTION_MODE=1  # Fail startup on risky config (DEBUG, SKIP_NOTION_API, missing ACTOR_SIGNING_SECRET, default DB passwords)
# NOTION_VALIDATE_DB_IDS_STRICT=1  # Fail startup if configured Notion DB IDs are invalid
